# Verstka (https://pypi.org/project/verstka-sdk/)
VERSTKA_API_KEY=
VERSTKA_API_SECRET=
# Public URL of this app where Verstka POSTs callbacks (must end with path used by nginx)
VERSTKA_CALLBACK_URL=https://example.com/verstka/callback
VERSTKA_API_URL=https://api.r2.verstka.org/integration

# Site
PUBLIC_BASE_URL=https://example.com
SESSION_SECRET=change-me-to-random-string
# DEBUG=1
# When enabled, logs each HTTP request/response (headers + body preview, truncated) to stdout. Do not use in production (secrets, cookies, passwords).

# SQLite (path relative to cwd or absolute)
DATABASE_URL=sqlite+aiosqlite:///./data.db

# Initial admin users (JSON object: user_email -> argon2id hash). Imported into cms_users when table is empty.
# Generate hash: python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('yourpassword'))"
# Password for this example hash is: admin  (change in production)
ADMINS={"admin":"$argon2id$v=19$m=65536,t=3,p=4$gM6WzLDgOf/MuhF3Bgj4fQ$uK4PiM9g5qXjtFVVeAuaZdIJVScSJzZ9gU90CyItP2k"}
