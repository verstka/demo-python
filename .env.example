# Verstka (https://pypi.org/project/verstka-sdk/)
VERSTKA_API_KEY=
VERSTKA_API_SECRET=
# Public URL of this app where Verstka POSTs callbacks (must end with path used by nginx)
VERSTKA_CALLBACK_URL=https://example.com/verstka/callback
VERSTKA_API_URL=https://api-stage.verstka.org/integration
# 1 loads https://stage.verstka.org/viewer-latest.js through the vendored verstka-viewer wrapper.
# Use 0 with production Verstka API/rendered articles.
VERSTKA_VIEWER_DEV=1

# Site
PUBLIC_BASE_URL=https://example.com
SESSION_SECRET=change-me-to-random-string
# DEBUG=1
# When enabled, logs each HTTP request/response (headers + body preview, truncated) to stdout. Do not use in production (secrets, cookies, passwords).

# SQLite (path relative to cwd or absolute)
DATABASE_URL=sqlite+aiosqlite:///./data.db

# Initial admin users (JSON object: user_email -> argon2id hash).
# Keep empty for first run so /cms/login can bootstrap the first admin email/password.
# Generate hash manually if you need to seed users:
# python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('yourpassword'))"
ADMINS={}
