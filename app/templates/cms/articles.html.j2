<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Articles — CMS</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 1rem 2rem; max-width: 56rem; }
    nav { margin-bottom: 1.5rem; }
    nav a { margin-right: 1rem; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #ccc; padding: 0.4rem 0.6rem; text-align: left; vertical-align: top; }
    th { background: #f5f5f5; }
    .mono { font-family: ui-monospace, monospace; font-size: 0.9rem; }
    fieldset { margin-top: 1.5rem; }
    .row { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
  </style>
</head>
<body>
  <nav>
    <a href="/cms/articles">Articles</a>
    <a href="/cms/users">Users</a>
    <a href="/cms/logout">Sign out</a>
  </nav>
  <h1>Articles</h1>
  <table>
    <thead>
      <tr>
        <th>Path</th>
        <th>Title</th>
        <th>Visible</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      {% for a in articles %}
      <tr>
        <td class="mono">{{ a.path }}</td>
        <td>{{ a.title }}</td>
        <td>{% if a.is_visible %}yes{% else %}no{% endif %}</td>
        <td>
          <div class="row">
            <a href="/cms/articles/open?path={{ a.path_q }}">Verstka editor</a>
            <form method="post" action="/cms/articles/visibility" style="display:inline">
              <input type="hidden" name="path" value="{{ a.path }}">
              <input type="hidden" name="is_visible" value="{{ 0 if a.is_visible else 1 }}">
              <button type="submit">{% if a.is_visible %}Hide{% else %}Show{% endif %}</button>
            </form>
            <form method="post" action="/cms/articles/delete" style="display:inline" onsubmit="return confirm('Delete this article?');">
              <input type="hidden" name="path" value="{{ a.path }}">
              <button type="submit">Delete</button>
            </form>
          </div>
          <form method="post" action="/cms/articles/og" enctype="multipart/form-data" style="margin-top:0.5rem">
            <input type="hidden" name="path" value="{{ a.path }}">
            <label>OG title <input name="og_title" value="{{ a.og_title or '' }}" style="width:12rem"></label>
            <label>OG description <input name="og_description" value="{{ a.og_description or '' }}" style="width:16rem"></label>
            <label>OG image <input type="file" name="og_image" accept=".jpg,.jpeg,.png,.webp,.gif"></label>
            <button type="submit">Save OG</button>
          </form>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  <fieldset>
    <legend>New article</legend>
    <form method="post" action="/cms/articles/create">
      <label>Path (e.g. /blog/hello) <input name="path" required class="mono" placeholder="/index"></label><br>
      <label>Title <input name="title" style="width:20rem"></label><br>
      <label>OG title <input name="og_title" style="width:20rem"></label><br>
      <label>OG description <input name="og_description" style="width:28rem"></label><br>
      <button type="submit">Create</button>
    </form>
  </fieldset>
</body>
</html>
